NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/review-radar
PROCESS_ROLE=all
REDIS_URL=redis://localhost:6379
APP_BASE_URL=http://localhost:3000
GITHUB_APP_ID=replace-me
GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-me\n-----END PRIVATE KEY-----"
SLACK_SIGNING_SECRET=replace-me
SLACK_BOT_TOKEN=xoxb-replace-me
DIGEST_CRON="0 9 * * 1-5"
# Optional IANA timezone. If unset, scheduled jobs use the deployment timezone/UTC.
DIGEST_TIMEZONE=UTC
REMINDER_CRON="0 * * * *"
STALE_REVIEW_DURATION_HOURS=24
REMINDER_COOLDOWN_HOURS=24
LOG_LEVEL=debug
